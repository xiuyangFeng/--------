{
  "run": {
    "experiment_name": "pointnetcfd_original_vp",
    "output_root": "outputs/external_baselines/pointnetcfd"
  },
  "data": {
    "data_root": "data_new/AG",
    "split_file": "training/splits/split_AG_v1.json",
    "graphs_subdir": "processed/graphs",
    "batch_size": 1,
    "num_workers": 0,
    "pin_memory": false,
    "node_features": ["x", "y", "z"],
    "global_features": ["t_norm", "BC_Inlet", "BC_O1", "BC_O2", "BC_O3", "BC_O4"]
  },
  "target": {
    "mode": "vp"
  },
  "model": {
    "point_hidden": 128,
    "global_hidden": 256,
    "decoder_hidden": 128,
    "dropout": 0.0
  },
  "optim": {
    "epochs": 200,
    "lr": 0.0005,
    "weight_decay": 0.0001,
    "early_stopping_patience": 30
  },
  "system": {
    "seed": 1,
    "device": "auto",
    "deterministic": true
  }
}
