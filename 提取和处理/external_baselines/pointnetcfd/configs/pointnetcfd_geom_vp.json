{
  "run": {
    "experiment_name": "pointnetcfd_geom_vp",
    "output_root": "outputs/external_baselines/pointnetcfd"
  },
  "data": {
    "data_root": "data_new/AG/fast",
    "split_file": "training/splits/split_example.json",
    "graphs_subdir": "processed/graphs",
    "batch_size": 2,
    "num_workers": 0,
    "pin_memory": false,
    "node_features": [
      "x", "y", "z",
      "Abscissa", "NormRadius", "Curvature",
      "Tangent_X", "Tangent_Y", "Tangent_Z",
      "is_wall"
    ],
    "global_features": ["t_norm", "BC_Inlet", "BC_O1", "BC_O2", "BC_O3", "BC_O4"]
  },
  "target": {
    "mode": "vp"
  },
  "model": {
    "point_hidden": 128,
    "global_hidden": 256,
    "decoder_hidden": 128,
    "dropout": 0.0
  },
  "optim": {
    "epochs": 200,
    "lr": 0.0005,
    "weight_decay": 0.0001,
    "early_stopping_patience": 30
  },
  "system": {
    "seed": 1,
    "device": "auto",
    "deterministic": true
  }
}
