    "feature_set": "coord_t_bc_geom_wall_physics",
    "ablation_axis": "physics_constraints",
    "tags": [
      "ablation",
      "physics",
      "continuity",
      "momentum",
      "no_slip"
    ],
    "notes": "任务A物理约束消融示例：数据 + continuity + momentum + no-slip。",
