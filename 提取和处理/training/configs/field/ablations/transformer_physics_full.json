{
  "run": {
    "experiment_name": "field_transformer_coord_t_bc_geom_wall_physics",
    "output_root": "outputs/field",
    "save_every": 10,
    "save_best_only": true
  },
  "data": {
    "data_root": "data_new/AG/fast",
    "split_file": "training/splits/split_example.json",
    "graphs_subdir": "processed/graphs",
    "preload": false,
    "batch_size": 2,
    "num_workers": 0,
    "pin_memory": false,
    "enabled_node_features": [
      "x",
      "y",
      "z",
      "Abscissa",
      "NormRadius",
      "Curvature",
      "Tangent_X",
      "Tangent_Y",
      "Tangent_Z",
      "is_wall"
