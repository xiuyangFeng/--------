  },
  "physics": {
    "enabled": true,
    "warmup_epochs": 20,
    "density": 1060.0,
    "viscosity": 0.0035,
    "coord_scales": [
      1.0,
      1.0,
      1.0
    ],
    "time_scale": 1.0,
    "continuity_weight": 0.1,
    "momentum_weight": 0.01,
    "no_slip_weight": 1.0,
    "eval_physics_on_val": false
  }
