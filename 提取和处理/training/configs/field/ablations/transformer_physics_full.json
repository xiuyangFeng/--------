  "optim": {
    "epochs": 200,
    "lr": 0.0005,
    "weight_decay": 0.0001,
    "scheduler_factor": 0.5,
    "scheduler_patience": 10,
    "early_stopping_patience": 30,
    "target_weights": [
      1.0,
      1.0,
      1.0,
      1.0
