      "BC_Inlet",
      "BC_O1",
      "BC_O2",
      "BC_O3",
      "BC_O4"
    ],
    "augment": true,
    "augment_config": {
      "rotation_prob": 0.5,
      "rotation_axes": "xyz",
      "translation_prob": 0.5,
      "translation_range": 0.1,
      "scale_prob": 0.0,
      "mirror_prob": 0.0
    }
  },
  "model": {
    "name": "transformer",
    "hidden_dim": 128,
    "num_layers": 3,
    "dropout": 0.1,
    "heads": 4
