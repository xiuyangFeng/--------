    "grad_clip_norm": 1.0,
    "accumulate_grad_batches": 1
  },
  "system": {
    "seed": 2,
    "device": "auto",
    "deterministic": true,
    "amp": false
  },
  "meta": {
    "task": "field",
    "exp_id": "A-Base-01",
    "stage": "task_a",
    "study_group": "baseline",
    "question": "建立无图结构下限，验证图建模是否有收益。",
    "feature_set": "coord_t_bc_point",
    "ablation_axis": "baseline_model",
    "tags": [
      "baseline",
      "mlp",
      "coord+t+bc"
    ],
    "notes": "任务A基线1：Point-wise MLP。",
    "generated_from": "training.scripts.make_field_plan"
  },
  "physics": {
    "enabled": false,
    "warmup_epochs": 0,
    "density": 1060.0,
    "viscosity": 0.0035,
    "coord_scales": [
      1.0,
      1.0,
      1.0
    ],
    "time_scale": 1.0,
    "continuity_weight": 0.0,
    "momentum_weight": 0.0,
    "no_slip_weight": 0.0,
    "auto_load_scales": true
  }
