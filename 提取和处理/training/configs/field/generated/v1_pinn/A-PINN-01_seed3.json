{
  "run": {
    "experiment_name": "field_transformer_opt05_pinn_steady",
    "output_root": "outputs/field",
    "save_every": 10,
    "save_best_only": true
  },
  "data": {
    "data_root": "data_new/AG",
    "split_file": "training/splits/split_AG_v1.json",
    "graphs_subdir": "processed/graphs",
    "preload": false,
    "batch_size": 2,
    "num_workers": 0,
    "pin_memory": false,
    "enabled_node_features": [
      "x",
      "y",
      "z",
      "Abscissa",
      "NormRadius",
      "Curvature",
      "Tangent_X",
      "Tangent_Y",
      "Tangent_Z",
      "is_wall"
    ],
    "enabled_global_features": [
      "t_norm",
      "BC_Inlet",
      "BC_O1",
      "BC_O2",
      "BC_O3",
      "BC_O4"
    ],
    "augment": true,
    "augment_config": {
      "rotation_prob": 0.5,
      "rotation_axes": "xyz",
      "translation_prob": 0.5,
      "translation_range": 0.1,
      "scale_prob": 0.0,
      "mirror_prob": 0.0
    }
  },
  "model": {
    "name": "transformer",
    "hidden_dim": 256,
    "num_layers": 4,
    "dropout": 0.1,
    "heads": 4,
    "use_transformer_prenorm": true
  },
  "optim": {
    "epochs": 200,
    "lr": 0.0005,
    "weight_decay": 0.0001,
    "warmup_epochs": 0,
    "scheduler_factor": 0.5,
    "scheduler_patience": 10,
    "early_stopping_patience": 30,
    "target_weights": [
      2.0,
      2.0,
      2.0,
      0.5
    ],
    "grad_clip_norm": 1.0,
    "accumulate_grad_batches": 1,
    "select_best_on_data_loss": true
  },
  "system": {
    "seed": 3,
    "device": "auto",
    "deterministic": true,
    "amp": false
  },
  "meta": {
    "task": "field",
    "exp_id": "A-PINN-01",
    "stage": "task_a",
    "study_group": "pinn_field",
    "question": "V1 母版 A-Opt-05 + 论文式 PINN（连续性+定常动量+物理 no-slip+动态 omega），只预测 u/v/w/p 是否提升场重建。",
    "feature_set": "coord_t_bc_geom_wall_pinn",
    "ablation_axis": "pinn_steady_full",
    "tags": [
      "v1",
      "pinn",
      "transformer",
      "steady",
      "velocity_pressure",
      "no_wss",
      "denormalize",
      "physical_no_slip",
      "dynamic_omega"
    ],
    "notes": "对照基线为同骨干无 physics 的 A-Opt-05；只预测 u/v/w/p（wss_dim=0、无 domain_loss）。physics 在 SI 物理量上算残差，no-slip 逼反归一化壁面速度→0，omega 每 10 轮按 data/physics 比例刷新。",
    "generated_from": "A-Opt-05_seed1.json + physics(PINN steady)"
  },
  "physics": {
    "enabled": true,
    "warmup_epochs": 20,
    "density": 1060.0,
    "viscosity": 0.0035,
    "coord_scales": [
      1.0,
      1.0,
      1.0
    ],
    "time_scale": 1.0,
    "continuity_weight": 0.1,
    "momentum_weight": 0.01,
    "no_slip_weight": 1.0,
    "auto_load_scales": true,
    "equation": "steady",
    "denormalize_fields": true,
    "length_unit_to_meter": 0.001,
    "no_slip_mode": "physical_zero",
    "dynamic_weight": true,
    "dynamic_weight_update_every": 10,
    "omega_init": 1.0,
    "eval_physics_on_val": false
  }
}