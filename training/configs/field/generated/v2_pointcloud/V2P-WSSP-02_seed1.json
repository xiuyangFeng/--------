    "accumulate_grad_batches": 2,
    "wss_loss_weight": 0.5,
    "wss_weights": [
      1.0,
      1.0,
      1.0,
      1.0
    ],
    "early_stop_wss_weight": 1.0
  },
  "system": {
    "seed": 1,
    "device": "auto",
    "deterministic": true,
    "amp": false
