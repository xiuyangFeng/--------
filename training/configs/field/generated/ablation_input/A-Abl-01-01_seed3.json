{
  "run": {
    "experiment_name": "field_transformer_coord_t",
    "output_root": "outputs/field",
    "save_every": 10,
    "save_best_only": true
  },
  "data": {
    "data_root": "data_new/AG/fast",
    "split_file": "training/splits/split_example.json",
    "graphs_subdir": "processed/graphs",
    "preload": false,
    "batch_size": 2,
    "num_workers": 0,
    "pin_memory": false,
    "enabled_node_features": [
      "x",
      "y",
      "z"
    ],
    "enabled_global_features": [
      "t_norm"
    ],
    "augment": true,
    "augment_config": {
      "rotation_prob": 0.5,
      "rotation_axes": "xyz",
      "translation_prob": 0.5,
      "translation_range": 0.1,
      "scale_prob": 0.0,
      "mirror_prob": 0.0
    }
  },
  "model": {
    "name": "transformer",
    "hidden_dim": 128,
    "num_layers": 3,
    "dropout": 0.1,
    "heads": 4
  },
  "optim": {
    "epochs": 200,
    "lr": 0.0005,
    "weight_decay": 0.0001,
    "scheduler_factor": 0.5,
    "scheduler_patience": 10,
    "early_stopping_patience": 30,
    "target_weights": [
      1.0,
      1.0,
      1.0,
      1.0
    ],
    "grad_clip_norm": 1.0
  },
  "system": {
    "seed": 3,
    "device": "auto",
    "deterministic": true
  },
  "meta": {
    "task": "field",
    "exp_id": "A-Abl-01-01",
    "stage": "task_a",
    "study_group": "ablation_input",
    "question": "边界条件、显式几何特征与 is_wall 分别带来什么贡献。",
    "feature_set": "coord_t",
    "ablation_axis": "input_features",
    "tags": [
      "ablation",
      "input_features",
      "coord_t"
    ],
    "notes": "输入特征层级消融：coords + t。",
    "generated_from": "training.make_field_plan"
  }
}